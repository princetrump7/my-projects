# --- Required ---
GOOGLE_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Optional: asset watchlist ---
MARKETPULSE_ASSETS=GOLD=GLD,SPY=SPY,NASDAQ=^IXIC,BTC=BTC-USD

# --- Optional: database path (default: marketpulse.db in project root) ---
MARKETPULSE_DB=marketpulse.db

# --- CI mode: run one test cycle and exit (set to false for normal use) ---
CI_ONE_SHOT=false
